# Server
PORT=5000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Admin
ADMIN_JWT_SECRET=admin_super_secret_key_different_from_user_jwt

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Google Gemini AI (for job summarization)
GEMINI_API_KEY=your_gemini_api_key

# FCM (Firebase Cloud Messaging - only for push notifications)
FCM_SERVER_KEY=your_fcm_server_key

# MSG91 (for OTP)
MSG91_API_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_template_id
MSG91_SENDER_ID=ROZGAR

# CORS
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
